{
	"name": "lbc-notifier",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run src/index.ts",
		"check": "biome check . && tsc --noEmit",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@maeldonnart/lbc-ts": "0.1.0",
		"postgres": "^3.4.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
